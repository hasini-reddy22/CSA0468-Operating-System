#include <stdio.h>

int main()
{
    int n, block[20], i;

    printf("Enter number of file blocks: ");
    scanf("%d", &n);

    printf("Enter block numbers:\n");
    for(i = 0; i < n; i++)
        scanf("%d", &block[i]);

    printf("\nLinked File Allocation\n");

    printf("\nBlock\tNext Block\n");

    for(i = 0; i < n - 1; i++)
    {
        printf("%d\t%d\n", block[i], block[i + 1]);
    }

    printf("%d\tNULL\n", block[n - 1]);

    printf("\nFirst Block: %d", block[0]);
    printf("\nLast Block : %d\n", block[n - 1]);

    return 0;
}
