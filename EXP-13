#include <stdio.h>

int main()
{
    int b[5] = {100, 500, 200, 300, 600};
    int p[4] = {212, 417, 112, 426};
    int i, j;

    for(i = 0; i < 4; i++)
    {
        for(j = 0; j < 5; j++)
        {
            if(p[i] <= b[j])
            {
                printf("Process %d allocated to Block %d\n", i + 1, j + 1);
                b[j] -= p[i];
                break;
            }
        }
    }
    return 0;
}
