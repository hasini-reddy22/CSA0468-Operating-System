#include <stdio.h>
#include <stdlib.h>

int main()
{
    FILE *fp;
    char ch, data[100];
    int choice;

    while(1)
    {
        printf("\n1. Create File");
        printf("\n2. Write to File");
        printf("\n3. Read File");
        printf("\n4. Append to File");
        printf("\n5. Exit");
        printf("\nEnter your choice: ");
        scanf("%d", &choice);

        switch(choice)
        {
            case 1:
                fp = fopen("sample.txt", "w");
                if(fp != NULL)
                {
                    printf("File created successfully.\n");
                    fclose(fp);
                }
                break;

            case 2:
                fp = fopen("sample.txt", "w");
                printf("Enter data: ");
                scanf(" %[^\n]", data);
                fprintf(fp, "%s", data);
                fclose(fp);
                printf("Data written successfully.\n");
                break;

            case 3:
                fp = fopen("sample.txt", "r");
                printf("\nFile Contents:\n");
                while((ch = fgetc(fp)) != EOF)
                    printf("%c", ch);
                fclose(fp);
                break;

            case 4:
                fp = fopen("sample.txt", "a");
                printf("Enter data to append: ");
                scanf(" %[^\n]", data);
                fprintf(fp, "%s", data);
                fclose(fp);
                printf("Data appended successfully.\n");
                break;

            case 5:
                exit(0);

            default:
                printf("Invalid choice.\n");
        }
    }

    return 0;
}
