#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>
#include <sys/stat.h>
#include <dirent.h>

int main()
{
    int fd;
    char buffer[100];
    struct stat s;
    DIR *d;
    struct dirent *dir;

    /* fcntl and open */
    fd = open("sample.txt", O_CREAT | O_RDWR, 0666);

    write(fd, "UNIX System Calls", 17);

    /* lseek */
    lseek(fd, 0, SEEK_SET);

    read(fd, buffer, 17);
    buffer[17] = '\0';

    printf("File Content: %s\n", buffer);

    /* stat */
    stat("sample.txt", &s);

    printf("File Size: %ld bytes\n", s.st_size);

    /* opendir and readdir */
    d = opendir(".");

    if (d != NULL)
    {
        printf("\nDirectory Contents:\n");

        while ((dir = readdir(d)) != NULL)
        {
            printf("%s\n", dir->d_name);
        }

        closedir(d);
    }

    close(fd);

    return 0;
}
