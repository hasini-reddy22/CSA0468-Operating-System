#include <stdio.h>

int main()
{
    int n, i, j, temp;
    int bt[10], wt[10], tat[10];
    float awt = 0, atat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("Burst Time P%d: ", i + 1);
        scanf("%d", &bt[i]);
    }

    /* Sort burst times in ascending order */
    for(i = 0; i < n - 1; i++)
        for(j = i + 1; j < n; j++)
            if(bt[i] > bt[j])
            {
                temp = bt[i];
                bt[i] = bt[j];
                bt[j] = temp;
            }

    wt[0] = 0;
    for(i = 1; i < n; i++)
        wt[i] = wt[i - 1] + bt[i - 1];

    printf("\nP\tBT\tWT\tTAT\n");

    for(i = 0; i < n; i++)
    {
        tat[i] = wt[i] + bt[i];
        awt += wt[i];
        atat += tat[i];

        printf("P%d\t%d\t%d\t%d\n", i + 1, bt[i], wt[i], tat[i]);
    }

    printf("\nAverage Waiting Time = %.2f", awt / n);
    printf("\nAverage Turnaround Time = %.2f", atat / n);

    return 0;
}
