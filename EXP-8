#include <stdio.h>

int main()
{
    int n, bt[10], rt[10], tq;
    int i, time = 0, remain;
    float wt = 0, tat = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++)
    {
        printf("Burst Time P%d: ", i + 1);
        scanf("%d", &bt[i]);
        rt[i] = bt[i];
    }

    printf("Enter Time Quantum: ");
    scanf("%d", &tq);

    remain = n;

    while(remain)
    {
        for(i = 0; i < n; i++)
        {
            if(rt[i] > 0)
            {
                if(rt[i] <= tq)
                {
                    time += rt[i];
                    wt += time - bt[i];
                    tat += time;
                    rt[i] = 0;
                    remain--;
                }
                else
                {
                    time += tq;
                    rt[i] -= tq;
                }
            }
        }
    }

    printf("\nAverage Waiting Time = %.2f", wt / n);
    printf("\nAverage Turnaround Time = %.2f", tat / n);

    return 0;
}
